APP_NAME=horizon-backend
APP_ENV=development
LOG_LEVEL=INFO

# Use your Neon connection string here. Keep sslmode=require.
DATABASE_URL=postgresql://username:password@ep-example.us-east-2.aws.neon.tech/horizon?sslmode=require
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=10
DATABASE_COMMAND_TIMEOUT=30

# Clerk backend auth
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_clerk_webhook_secret
CLERK_AUTHORIZED_PARTIES=["http://localhost:3000"]
